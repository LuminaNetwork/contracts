{
  "name": "@luminapkg/contracts",
  "version": "1.0.1",
  "description": "Protobuf definitions and generated Typescript types",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "generate": "protoc -I ./proto ./proto/*.proto --ts_proto_out=./generated/typescript --ts_proto_opt=nestJs=true,package=omit,stringEnums=true,useDate=string"
  },
  "files": [
    "proto",
    "generated",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "@nestjs/microservices": "^11.1.28",
    "rxjs": "^7.8.2",
    "ts-proto": "^2.12.0"
  }
}
